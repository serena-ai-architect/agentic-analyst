# ══════════════════════════════════════════════════════════════
# LLM Provider API Keys
# ══════════════════════════════════════════════════════════════

# DeepSeek (default provider — cheap, good Chinese quality)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI (optional — for GPT models)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (optional — for Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ══════════════════════════════════════════════════════════════
# Model Routing (per-stage model assignment)
# ══════════════════════════════════════════════════════════════
# All default to "deepseek-chat" if not set.
# Mix and match providers by model name:
#   deepseek-chat / deepseek-reasoner → DeepSeek API
#   gpt-4o / gpt-4.1 / gpt-4.1-mini  → OpenAI API
#   claude-sonnet-4-6 / claude-haiku-4-5 → Anthropic API

PLANNING_MODEL=deepseek-chat
RESEARCH_MODEL=deepseek-chat
ANALYSIS_MODEL=deepseek-chat
REPORT_MODEL=deepseek-chat
TRANSLATION_MODEL=deepseek-chat
EVALUATION_MODEL=deepseek-chat

# ══════════════════════════════════════════════════════════════
# Integrations
# ══════════════════════════════════════════════════════════════

# Notion (save reports to knowledge base)
NOTION_API_KEY=ntn_your-notion-integration-token
NOTION_DATABASE_ID=your-database-id-here

# Email Notifications (send report emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_TO=you@gmail.com

# Optional: LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_PROJECT=multi-agent-research-ts
